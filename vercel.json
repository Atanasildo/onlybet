{
  "version": 2,
  "builds": [
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "public/admin/index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/admin/?", "dest": "/public/admin/index.html" },
    { "src": "/admin/(.*)", "dest": "/public/admin/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}