{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "onlybet-patch.js", "use": "@vercel/static" },
    { "src": "admin/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/admin(.*)", "dest": "/api/admin.js" },
    { "src": "/api/auth(.*)", "dest": "/api/auth.js" },
    { "src": "/api/transacoes(.*)", "dest": "/api/transacoes.js" },
    { "src": "/api/football(.*)", "dest": "/api/football.js" },
    { "src": "/api/odds(.*)", "dest": "/api/odds.js" },
    { "src": "/api/deposito(.*)", "dest": "/api/deposito.js" },
    { "src": "/admin", "dest": "/admin/index.html" },
    { "src": "/admin/", "dest": "/admin/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
